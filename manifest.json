{
  "name": "EZ Cat Search",
  "description": "An easy way to de-stress by looking up a cat picture",
  "version": "1.67",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html",
    "default_icon": "./images/icon.png"
  },
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png"
  },
  "background": {
    "service_worker": "OS-sw.js",
    "type": "module"
  },
  "permissions": ["alarms", "tabs", "activeTab", "scripting"]
}